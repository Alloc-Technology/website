---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;
const { contact_form_action } = config.params;
const { title, description, info } = entry.data;
---

<Base title={title} description={description}>
  <section class="section">
    <div class="container">
      <h1 class="text-center font-normal" set:html={markdownify(title)} />
      <div class="section row pb-0">
        <div class="col-12 md:col-6 lg:col-7">
          <form class="contact-form" id="contact-form" method="POST" action={contact_form_action}>
            <div class="form-section mb-6">
              <h3 class="text-lg font-semibold text-text-dark mb-4 border-b pb-2">Personal Information</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="name">Name *</label>
                  <input
                    class="form-input w-full rounded"
                    name="name"
                    type="text"
                    id="name"
                    placeholder="John Doe"
                    required
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="email">Email *</label>
                  <input
                    class="form-input w-full rounded"
                    name="email"
                    type="email"
                    id="email"
                    placeholder="john@company.com"
                    required
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="company">Company</label>
                  <input
                    class="form-input w-full rounded"
                    name="company"
                    type="text"
                    id="company"
                    placeholder="Your company"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="phone">Phone</label>
                  <input
                    class="form-input w-full rounded"
                    name="phone"
                    type="tel"
                    id="phone"
                    placeholder="+1 (555) 000-0000"
                  />
                </div>
              </div>
            </div>

            <div class="form-section mb-6">
              <h3 class="text-lg font-semibold text-text-dark mb-4 border-b pb-2">Project Details</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="topic">What can we help you with? *</label>
                  <select
                    class="form-input w-full rounded"
                    name="topic"
                    id="topic"
                    required
                  >
                    <option value="" disabled selected>Select a topic</option>
                    <option value="containers-kubernetes">Containers & Kubernetes</option>
                    <option value="ci-cd-pipelines">CI/CD Pipelines</option>
                    <option value="cloud-infrastructure">Cloud Infrastructure (AWS/Azure/GCP)</option>
                    <option value="cloud-security">Cloud Security</option>
                    <option value="cost-optimization">Cost Optimization</option>
                    <option value="infrastructure-as-code">Infrastructure as Code (Terraform/CloudFormation)</option>
                    <option value="monitoring-observability">Monitoring & Observability</option>
                    <option value="migration-services">Migration Services</option>
                    <option value="devops-consulting">DevOps Consulting</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-text-dark mb-1" for="budget">Budget range</label>
                  <select
                    class="form-input w-full rounded"
                    name="budget"
                    id="budget"
                  >
                    <option value="" disabled selected>Select budget (optional)</option>
                    <option value="under-5k">Under $5,000</option>
                    <option value="5k-20k">$5,000 - $20,000</option>
                    <option value="20k-50k">$20,000 - $50,000</option>
                    <option value="50k-plus">$50,000+</option>
                    <option value="not-sure">Not sure yet</option>
                  </select>
                </div>
                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-text-dark mb-1" for="timeline">Timeline</label>
                  <select
                    class="form-input w-full rounded"
                    name="timeline"
                    id="timeline"
                  >
                    <option value="" disabled selected>When do you need this? (optional)</option>
                    <option value="immediately">Immediately</option>
                    <option value="1-3-months">1-3 months</option>
                    <option value="3-6-months">3-6 months</option>
                    <option value="just-researching">Just researching</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-section mb-6">
              <h3 class="text-lg font-semibold text-text-dark mb-4 border-b pb-2">Your Message</h3>
              <div>
                <label class="block text-sm font-medium text-text-dark mb-1" for="message">Tell us about your project *</label>
                <textarea
                  class="form-textarea w-full rounded-md"
                  name="message"
                  id="message"
                  rows="5"
                  placeholder="Describe your project, goals, and any specific requirements..."
                  required></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn-primary w-full md:w-auto px-8" id="submit-btn">Send Message</button>
            <div id="form-status" class="mt-4 p-3 rounded bg-gray-50"></div>
          </form>
        </div>
        <div class="content col-12 md:col-6 lg:col-5">
          <h4 set:html={markdownify(info?.title)} />
          <p class="mt-4" set:html={markdownify(info?.description)} />
          <ul class="contact-list mt-5 list-none pl-0">
            {
              info?.contacts?.map((contact) => (
                <li>
                  <strong
                    class="text-text-dark"
                    set:html={markdownify(contact)}
                  />
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const statusDiv = document.getElementById("form-status") as HTMLDivElement | null;

  if (!form || !submitBtn || !statusDiv) {
    throw new Error("Required form elements not found");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";
    statusDiv!.innerHTML = "";

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: {
          "Accept": "application/json"
        }
      });

      if (response.ok) {
        statusDiv!.innerHTML = '<p class="text-green-600 font-medium">Thank you! We\'ll be in touch soon.</p>';
        form.reset();
      } else {
        const data = await response.json();
        if (data.errors) {
          statusDiv!.innerHTML = '<p class="text-red-600">Please fill in all required fields correctly.</p>';
        } else {
          statusDiv!.innerHTML = '<p class="text-red-600">Something went wrong. Please try again.</p>';
        }
      }
    } catch (error) {
      statusDiv!.innerHTML = '<p class="text-red-600">Something went wrong. Please try again.</p>';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = "Send Now";
  });
</script>
